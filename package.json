{
  "name": "context-clipboard",
  "version": "0.6.0",
  "description": "Smart clipboard manager for Chrome, Brave, and Firefox. Remembers source URL + context for every copy, including images.",
  "private": true,
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:chrome": "node scripts/build.mjs chrome",
    "build:firefox": "node scripts/build.mjs firefox",
    "watch": "node scripts/build.mjs --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/firefox-webext-browser": "^120.0.5",
    "esbuild": "^0.25.0",
    "playwright": "^1.60.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "tesseract.js": "^5.1.0"
  }
}
